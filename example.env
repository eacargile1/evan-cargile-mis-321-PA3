# Copy to `.env` in this folder (gitignored) or set env vars in the shell / PaaS dashboard.
# Do not put real API keys in this file if you commit the repo to GitHub.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=cs2_tactical

# Railway MySQL plugin often exposes MYSQLHOST, MYSQLPORT, MYSQLUSER, MYSQLPASSWORD, MYSQLDATABASE (no underscores).
# The app accepts either style; use variable references from the DB service or copy values into MYSQL_* names.

# Cloud MySQL: start unset (defaults to Preferred). If you get SSL errors, try: Required, VerifyCA, or VerifyFull (provider-specific).
# MYSQL_SSL_MODE=Preferred

# PaaS (Heroku, Railway, Render, Fly): set MYSQL_* in the provider’s UI, not in a committed file.

# HLTV bridge (local): second terminal: cd hltv-bridge && npm install && npm start
# Must match the bridge. Local-only bind: HLTV_BRIDGE_HOST=127.0.0.1
# In production, deploy hltv-bridge as a second service and set this to that service’s public https URL (never 127.0.0.1 in the cloud):
HLTV_BRIDGE_URL=http://127.0.0.1:3847
